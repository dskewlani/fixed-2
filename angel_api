def get_candle_data(
    token: str,
    exchange: str,
    symbol_token: str,
    interval: str,
    from_date: str,
    to_date: str,
) -> list:
    """
    Fetch OHLCV candle data.

    Args:
        token        : instrument token
        exchange     : "NSE" | "BSE" | "NFO"
        symbol_token : same as token (SmartAPI quirk)
        interval     : "ONE_MINUTE" | "FIVE_MINUTE" | "ONE_HOUR" | "ONE_DAY" etc.
        from_date    : "YYYY-MM-DD HH:MM"
        to_date      : "YYYY-MM-DD HH:MM"

    Returns:
        List of [timestamp, open, high, low, close, volume]
    """
    ensure_logged_in()
    try:
        param = {
            "exchange":    exchange,
            "symboltoken": symbol_token,
            "interval":    interval,
            "fromdate":    from_date,
            "todate":      to_date,
        }
        resp = _obj.getCandleData(param)
        if resp and resp.get("status"):
            return resp["data"]
        raise ValueError(f"Candle fetch failed: {resp}")
    except Exception:
        logger.exception("angel_api: get_candle_data failed")
        raise


