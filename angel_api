"""
angel_api.py
------------
Angel One SmartAPI wrapper for Streamlit apps.

Fill in your credentials in the CONFIG section below (or load from
environment variables / st.secrets). Everything else is ready to use.

Install the dependency first:
    pip install smartapi-python pyotp

Usage:
    import angel_api
    status = angel_api.get_status()          # {"authenticated": bool, ...}
    ltp    = angel_api.get_ltp("NSE", "RELIANCE", "2885")
    orders = angel_api.get_order_book()
    angel_api.place_order(...)
    angel_api.logout()
"""

import os
import logging

logger = logging.getLogger(__name__)

# ── CONFIG ────────────────────────────────────────────────────────────────────
# Option A: hard-code here (for local dev only — never commit secrets!)
API_KEY     = os.getenv("ANGEL_API_KEY",     "WKZ1Ve6i")
CLIENT_ID   = os.getenv("ANGEL_CLIENT_ID",   "K258077")
PASSWORD    = os.getenv("ANGEL_PASSWORD",     "1811")   # login PIN / password
TOTP_SECRET = os.getenv("ANGEL_TOTP_SECRET", "HBIWFBUKBUJ4XXNY6MUTE65WIM")

# Option B (recommended for Streamlit Cloud): put the above in .streamlit/secrets.toml
# and load like:
#   import streamlit as st
#   API_KEY = st.secrets["ANGEL_API_KEY"]
# ─────────────────────────────────────────────────────────────────────────────

# Internal state
_obj   = None   # SmartConnect instance
_data  = {}     # session data returned after login
_authenticated = False


def _is_stub_config() -> bool:
    """Returns True if credentials are still the placeholder defaults."""
    return (
        API_KEY     == "YOUR_API_KEY"     or
        CLIENT_ID   == "YOUR_CLIENT_ID"   or
        TOTP_SECRET == "YOUR_TOTP_SECRET"
    )


# ── AUTH ──────────────────────────────────────────────────────────────────────

def login() -> dict:
    """
    Authenticate with Angel One using SmartAPI + TOTP.
    Returns the session dict on success, raises on failure.
    """
    global _obj, _data, _authenticated

    if _is_stub_config():
        logger.warning("angel_api: using STUB mode — credentials not set.")
        _authenticated = False
        return {"status": False, "message": "Stub mode — fill in credentials"}

    try:
        import pyotp
        from SmartApi import SmartConnect

        totp = pyotp.TOTP(TOTP_SECRET).now()

        _obj  = SmartConnect(api_key=API_KEY)
        _data = _obj.generateSession(CLIENT_ID, PASSWORD, totp)

        if _data and _data.get("status"):
            _authenticated = True
            logger.info("angel_api: login successful for %s", CLIENT_ID)
            return _data
        else:
            _authenticated = False
            logger.error("angel_api: login failed — %s", _data)
            return _data or {"status": False, "message": "Unknown login error"}

    except ImportError as e:
        raise ImportError(
            "Missing dependency. Run:  pip install smartapi-python pyotp"
        ) from e
    except Exception as e:
        _authenticated = False
        logger.exception("angel_api: login exception")
        raise


def logout() -> dict:
    """Terminate the current session."""
    global _obj, _data, _authenticated
    if _obj and _authenticated:
        try:
            result = _obj.terminateSession(CLIENT_ID)
            _authenticated = False
            _obj = None
            _data = {}
            return result
        except Exception as e:
            logger.exception("angel_api: logout failed")
            raise
    _authenticated = False
    return {"status": True, "message": "No active session"}


def ensure_logged_in():
    """Auto-login if not already authenticated."""
    if not _authenticated:
        login()


# ── STATUS ────────────────────────────────────────────────────────────────────

def get_status() -> dict:
    """
    Returns a status dict consumed by your Streamlit dashboard.

    Shape:
        {
            "authenticated": bool,
            "configured": bool,   # True if real credentials are set (even if not yet logged in)
            "client_id": str,
            "stub_mode": bool,
            "message": str,
            "session_data": dict | None,
        }
    """
    if _is_stub_config():
        return {
            "authenticated": False,
            "configured": False,
            "client_id": CLIENT_ID,
            "stub_mode": True,
            "message": "Stub mode — set ANGEL_API_KEY, ANGEL_CLIENT_ID, ANGEL_PASSWORD, ANGEL_TOTP_SECRET",
            "session_data": None,
        }

    return {
        "authenticated": _authenticated,
        "configured": True,       # credentials are set; login may or may not have run yet
        "client_id": CLIENT_ID,
        "stub_mode": False,
        "message": "Connected" if _authenticated else "Not logged in",
        "session_data": _data if _authenticated else None,
    }


# ── MARKET DATA ───────────────────────────────────────────────────────────────

def get_ltp(exchange: str, symbol: str, token: str) -> dict:
    """
    Fetch Last Traded Price for a symbol.

    Args:
        exchange : "NSE" | "BSE" | "NFO" | "MCX"
        symbol   : e.g. "RELIANCE"
        token    : Angel One instrument token, e.g. "2885"

    Returns:
        {"ltp": float, "exchange": str, "symbol": str}
    """
    ensure_logged_in()
    try:
        resp = _obj.ltpData(exchange, symbol, token)
        if resp and resp.get("status"):
            return {
                "ltp":      resp["data"]["ltp"],
                "exchange": exchange,
                "symbol":   symbol,
            }
        raise ValueError(f"LTP fetch failed: {resp}")
    except Exception:
        logger.exception("angel_api: get_ltp failed")
        raise


def get_market_data(mode: str, exchange_tokens: dict) -> dict:
    """
